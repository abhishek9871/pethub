# ──────────────────────────────────────────────────
# PetHub Environment Variables
# ──────────────────────────────────────────────────

# PayPal Client ID (safe for frontend — loads the PayPal JS SDK)
# Get from https://developer.paypal.com/dashboard/applications
VITE_PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID_HERE"

# ──────────────────────────────────────────────────
# The following secrets are stored in .dev.vars (local)
# or as Cloudflare Pages secrets (production).
# They are NEVER exposed to the frontend.
# ──────────────────────────────────────────────────
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...
# PAYPAL_MODE=sandbox  (or "live" for production)
